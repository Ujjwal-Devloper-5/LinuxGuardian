# ═══════════════════════════════════════════════════════════════
#  LinuxGuardian — Configuration File
#  Generated by: linuxguardian init
#  Documentation: https://github.com/ujjwal/linuxguardian
# ═══════════════════════════════════════════════════════════════

# ── General ───────────────────────────────────────────────────
BACKUP_NAME="my-system"
DATA_DIR="/var/lib/linuxguardian"
LOG_DIR="/var/lib/linuxguardian/logs"
LOG_RETENTION_DAYS=30

# ── Backup Repositories ──────────────────────────────────────
HOME_REPO="/var/lib/linuxguardian/repos/home"
SYSTEM_REPO="/var/lib/linuxguardian/repos/system"
RESTIC_PASSWORD_FILE="/var/lib/linuxguardian/.restic-password"

# ── Backup Sources ────────────────────────────────────────────
HOME_SOURCES="/home"
SYSTEM_SOURCES="/"
HOME_EXCLUDE_FILE="/etc/linuxguardian/exclude-home.txt"
SYSTEM_EXCLUDE_FILE="/etc/linuxguardian/exclude-system.txt"

# ── Schedule ──────────────────────────────────────────────────
HOME_SCHEDULE="daily"
HOME_TIME="02:00"
SYSTEM_SCHEDULE="weekly"
SYSTEM_DAY="Sun"
SYSTEM_TIME="03:00"

# ── Smart Scheduling (AI) ────────────────────────────────────
SMART_SCHEDULE_ENABLED=true
IDLE_THRESHOLD_MS=600000
CPU_IDLE_THRESHOLD=80
MAX_DEFER_HOURS=6
METRICS_INTERVAL_SEC=300

# ── Cloud Sync ────────────────────────────────────────────────
CLOUD_ENABLED=true
CLOUD_REMOTE="mycloud"
CLOUD_PATH="linuxguardian"
CLOUD_PROVIDER=""
RCLONE_CONFIG="/etc/linuxguardian/rclone.conf"
RCLONE_BW_LIMIT="0"
RCLONE_TRANSFERS=4

# ── Retention (GFS — Grandfather-Father-Son) ─────────────────
KEEP_DAILY=7
KEEP_WEEKLY=4
KEEP_MONTHLY=12
KEEP_YEARLY=3

# ── Resource Limits ───────────────────────────────────────────
NICE_LEVEL=19
IO_CLASS="idle"
CPU_QUOTA="50%"
IO_WEIGHT=20
MEMORY_MAX="1G"

# ── Notifications ─────────────────────────────────────────────
NOTIFY_ENABLED=true
NOTIFY_ON_SUCCESS=true
NOTIFY_ON_FAILURE=true
NOTIFY_SOUND_ENABLED=true
NOTIFY_SOUND_SUCCESS="/usr/share/linuxguardian/sounds/backup-success.oga"
NOTIFY_SOUND_ERROR="/usr/share/linuxguardian/sounds/backup-error.oga"

# ── AI Features ───────────────────────────────────────────────
ANOMALY_DETECTION=true
ANOMALY_ZSCORE_WARN=2.0
ANOMALY_ZSCORE_CRITICAL=3.0
STORAGE_PREDICTION=true
INTEGRITY_VERIFY=true
LOG_ANALYSIS=true
HEALTH_SCORE=true
